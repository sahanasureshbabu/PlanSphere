<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="PlanSphere Android Appium E2E Suite" verbose="2" parallel="none">
    <listeners>
        <listener class-name="com.plansphere.listeners.ExecutionListener" />
        <listener class-name="com.plansphere.listeners.AnnotationTransformer" />
    </listeners>
    <test name="E2E Functional Verification">
        <classes>
            <class name="com.plansphere.tests.AppiumE2ETest" />
        </classes>
    </test>
</suite>
